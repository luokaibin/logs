{
  "name": "logbeacon-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "浏览器端日志上报",
  "scripts": {
    "build": "turbo run build --filter=@logbeacon/core --filter=@logbeacon/web --filter=@logbeacon/ingest",
