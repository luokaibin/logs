{
  "name": "@logbeacon/react-native",
  "version": "1.7.2",
  "type": "module",
  "main": "./dist/sls/logs.js",
  "module": "./dist/sls/logs.js",
  "react-native": "./dist/sls/logs.js",
  "description": "React Native 日志采集与上报（阿里云 SLS / Grafana Loki），入口与 Web core/logs 对齐并按变体分包",
  "exports": {
    ".": {
      "import": "./dist/sls/logs.js",
      "require": "./dist/sls/logs.cjs",
      "types": "./dist/types/logs.d.ts",
      "default": "./dist/sls/logs.js"
    },
    "./sls": {
      "import": "./dist/sls/logs.js",
      "require": "./dist/sls/logs.cjs",
      "types": "./dist/types/logs.d.ts",
      "default": "./dist/sls/logs.js"
    },
    "./loki": {
      "import": "./dist/loki/logs.js",
      "require": "./dist/loki/logs.cjs",
      "types": "./dist/types/logs.d.ts",
      "default": "./dist/loki/logs.js"
    },
    "./eslint": {
      "require": "./dist/eslint/index.js",
      "import": "./dist/eslint/index.mjs",
      "default": "./dist/eslint/index.mjs",
      "types": "./dist/types/eslintPlugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "dev:RN": "rollup -c rollup.config.js -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -rf dist",
    "proto:compile": "pnpx pbf common/log.proto > common/log.proto.js"
  },
  "keywords": [
    "logbeacon",
    "logs",
    "logger",
    "logging",
    "browser",
    "browser-logs",
    "client-logging",
    "service-worker",
    "loki",
    "grafana",
    "sls",
    "aliyun",
    "error-tracking",
    "log-aggregation",
    "log-collection",
    "log-shipping"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/luokaibin/logs.git"
  },
  "bugs": {
    "url": "https://github.com/luokaibin/logs/issues"
  },
  "homepage": "https://github.com/luokaibin/logs#readme",
  "license": "MIT",
  "peerDependencies": {
    "react-native": ">=0.64.0",
    "react-native-quick-sqlite": ">=8.2.7"
  },
  "dependencies": {
    "@logbeacon/core": "workspace:*",
    "fflate": "^0.8.2",
    "pbf": "^4.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^3.20.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}