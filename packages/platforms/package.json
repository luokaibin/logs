{
  "name": "@logbeacon/platforms",
  "version": "1.7.2",
  "type": "module",
  "description": "受支持日志平台的适配实现：阿里云 SLS、Grafana Loki 等编码与客户端（与 @logbeacon/core 编排层解耦）。",
  "exports": {
    "./sls-encoder": "./sls/logEncoder.js",
    "./sls-client": "./sls/slsClient.js",
    "./loki-encoder": "./loki/logEncoder.js",
    "./loki-client": "./loki/lokiClient.js"
  },
  "files": [
    "sls",
    "loki"
  ],
  "scripts": {
    "proto:compile": "pbf sls/sls.proto > sls/sls.js"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "pbf": "^4.0.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luokaibin/logs.git",
    "directory": "packages/platforms"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
