{
  "name": "@logbeacon/core",
  "version": "1.7.2",
  "type": "module",
  "description": "日志编排与公共能力（聚合、去重、SLS/Loki 客户端与编码等）。需由平台层实现持久化（如浏览器侧 IndexedDB）；本包不提供可单独运行的完整存储实现。要求运行环境原生支持 fetch。",
  "exports": {
    "./sls-client": {
      "import": "./sls/slsClient.js",
      "default": "./sls/slsClient.js"
    },
    "./sls-encoder": {
      "import": "./sls/logEncoder.js",
      "default": "./sls/logEncoder.js"
    },
    "./loki-client": {
      "import": "./loki/lokiClient.js",
      "default": "./loki/lokiClient.js"
    },
    "./loki-encoder": {
      "import": "./loki/logEncoder.js",
      "default": "./loki/logEncoder.js"
    },
    "./serializeLogContent": {
      "import": "./common/serializeLogContent.js",
      "default": "./common/serializeLogContent.js"
    },
    "./utils": {
      "import": "./common/utils.js",
      "default": "./common/utils.js"
    },
    "./console-logger": {
      "import": "./common/ConsoleLogger.js",
      "default": "./common/ConsoleLogger.js"
    },
    "./constants": {
      "import": "./common/constants.js",
      "default": "./common/constants.js"
    },
    "./LogProcessor": {
      "import": "./common/LogProcessor.js",
      "default": "./common/LogProcessor.js"
    },
    "./LogAggregator": {
      "import": "./common/LogAggregator.js",
      "default": "./common/LogAggregator.js"
    },
    "./LogStore": {
      "import": "./common/LogStore.js",
      "default": "./common/LogStore.js"
    },
    "./LogStorageBase": {
      "import": "./common/LogStorageBase.js",
      "default": "./common/LogStorageBase.js"
    }
  },
  "files": [
    "sls",
    "loki",
    "common"
  ],
  "scripts": {
    "proto:compile": "pbf sls/sls.proto > sls/sls.js"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luokaibin/logs.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
