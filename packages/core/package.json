{
  "name": "@logbeacon/core",
  "version": "1.7.2",
  "type": "module",
  "description": "日志编排与公共能力（聚合、去重、持久化抽象等）。SLS/Loki 等平台适配见 @logbeacon/platforms。需由宿主实现持久化；要求运行环境原生支持 fetch。",
  "exports": {
    "./serializeLogContent": {
      "import": "./lib/esm/serializeLogContent.js",
      "default": "./lib/esm/serializeLogContent.js"
    },
    "./utils": {
      "import": "./lib/esm/utils.js",
      "default": "./lib/esm/utils.js"
    },
    "./console-logger": {
      "import": "./lib/esm/console-logger.js",
      "default": "./lib/esm/console-logger.js"
    },
    "./constants": {
      "import": "./lib/esm/constants.js",
      "default": "./lib/esm/constants.js"
    },
    "./LogProcessor": {
      "import": "./lib/esm/LogProcessor.js",
      "default": "./lib/esm/LogProcessor.js"
    },
    "./LogAggregator-sls": {
      "import": "./lib/esm/LogAggregator-sls.js",
      "default": "./lib/esm/LogAggregator-sls.js"
    },
    "./LogAggregator-loki": {
      "import": "./lib/esm/LogAggregator-loki.js",
      "default": "./lib/esm/LogAggregator-loki.js"
    },
    "./LogStore": {
      "import": "./lib/esm/LogStore.js",
      "default": "./lib/esm/LogStore.js"
    },
    "./LogStorageBase": {
      "import": "./lib/esm/LogStorageBase.js",
      "default": "./lib/esm/LogStorageBase.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "proto:compile": "pnpm --filter @logbeacon/platforms run proto:compile"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@logbeacon/platforms": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rollup": "^4.28.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luokaibin/logs.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
